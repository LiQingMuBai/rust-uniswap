# 以太坊 RPC 地址；建议使用自己的 Alchemy/Infura/自建节点。
RPC_URL=

# WSS RPC 地址；watch-blocks 模式使用它订阅新区块。
WS_RPC_URL=

# 日志级别：info 适合日常运行，debug 可用于排查报价失败原因。
RUST_LOG=info

# 运行模式：dry_run 只打印机会；live 会提交执行合约交易。
RUN_MODE=dry_run

# 持续 watch 模式的扫描间隔，单位秒。
POLL_INTERVAL_SECS=12

# 最小利润阈值，单位 bps；20 = 0.20%。
MIN_PROFIT_BPS=20

# 预估执行交易 gas limit，用于净利润扣减。
GAS_LIMIT=350000

# 最大 gas price，单位 gwei；用于保守估算 gas 成本。
MAX_GAS_PRICE_GWEI=35

# 调试报价开关；true 会打印每条路线的报价和过滤原因。
DEBUG_QUOTES=false

# 主网 WETH 地址；也用于判断是否可以按 ETH gas 成本扣减净利润。
WETH_ADDRESS=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2

# 主网 LINK 地址。
LINK_ADDRESS=0x514910771AF9Ca656af840dff83E8264EcF986CA

# 主网 UNI 地址。
UNI_ADDRESS=0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984

# 主网 AAVE 地址。
AAVE_ADDRESS=0x7Fc66500c84A76Ad7e9c93437bFc5Ac33E2DDaE9

# 主网 WBTC 地址。
WBTC_ADDRESS=0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599

# 单次尝试输入金额，单位 wei；这里是 1 WETH。
TRADE_AMOUNT_WEI=1000000000000000000

# Uniswap V2 WETH/LINK pair 地址。
UNISWAP_V2_WETH_LINK_PAIR=0xA2107Fa5B38d9bbd2C461D6EDf11B11A50F6b974

# Uniswap V2 WETH/UNI pair 地址。
UNISWAP_V2_WETH_UNI_PAIR=0xd3d2E2692501A5c9Ca623199D38826e513033a17

# Uniswap V2 WETH/AAVE pair 地址。
UNISWAP_V2_WETH_AAVE_PAIR=0xDFC14d2Af169B0D36C4EFF567Ada9b2E0CAE044f

# Uniswap V2 WETH/WBTC pair 地址。
UNISWAP_V2_WETH_WBTC_PAIR=0xBb2b8038a1640196FbE3e38816F3e67Cba72D940

# Uniswap V2 Router02 地址。
UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# Uniswap V2 手续费，单位 bps；30 = 0.30%。
UNISWAP_V2_FEE_BPS=30

# Uniswap V3 Quoter 地址；用于 eth_call 报价，不会发交易。
UNISWAP_V3_QUOTER=0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6

# Uniswap V3 SwapRouter 地址。
UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564

# Uniswap V3 fee tier；WETH/LINK 先用 3000 = 0.30%。
UNISWAP_V3_FEE=3000

# 下面三个只在 config.yaml 启用 executor 且 RUN_MODE=live 时需要。
EXECUTOR_ADDRESS=0xYourExecutorContract

# 真实私钥只能放本地 .env，不能提交到仓库。
PRIVATE_KEY=0xYourPrivateKey

# 交易过期时间，单位秒；过短容易失败，过长会增加价格变化风险。
DEADLINE_SECS=60
